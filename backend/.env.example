QPAY_USERNAME=your-qpay-client-id
QPAY_PASSWORD=your-qpay-client-secret
QPAY_INVOICE_CODE=your-qpay-invoice-code
QPAY_CALLBACK_TOKEN=replace-with-random-callback-token

SUPERADMIN_NAME=Platform Superadmin
