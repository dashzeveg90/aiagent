PORT=5005
NODE_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/aiagent

JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRE=7d

OPENAI_API_KEY=your-openai-api-key
PINECONE_API_KEY=your-pinecone-api-key
